# Copy to `.env` (docker compose auto-loads it). All values are OPTIONAL.

# Enables the in-conversation web-search tool. Get a key at https://serper.dev
# Leave blank/omit to run without the search tool.
SERPER_API_KEY=

# Default speech-to-speech backend (a load balancer that speaks the OpenAI
# Realtime protocol over WebSocket). Leave BLANK to use "direct mode" and enter
# your own s2s server URL in the app's Settings panel instead.
LOAD_BALANCER_URL=

# Direct-mode default server URL, pre-filled into Settings so it connects out of
# the box. Must be a realtime speech-to-speech WebSocket endpoint (same protocol
# as the repo's backend), NOT a /v1/chat/completions text endpoint. Include the
# ws:// (or wss://) scheme and the realtime path.
DEFAULT_S2S_URL=ws://5.6.7.8:4567/v1/realtime
